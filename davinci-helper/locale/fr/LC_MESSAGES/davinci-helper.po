#: davinci_helper/functions/gui/check_update_dialog_gui.py:104
msgid "A new update is available"
msgstr "Une nouvelle mise à jour est disponible"

#: davinci_helper/functions/gui/check_update_dialog_gui.py:107
msgid ""
"A new version of this app has been found.\n"
"We recommend you to update it before continue using it."
msgstr ""
"Une nouvelle version de cette application a été trouvée.\n"
"Nous vous recommandons de la mettre à jour avant de continuer à l'utiliser."

#: davinci_helper/functions/gui/converter_dialog_gui.py:101
msgid "Select a valid file"
msgstr "Sélectionnez un fichier valide"

#: davinci_helper/functions/gui/converter_dialog_gui.py:104
msgid ""
"It seems like you didn't load any file to convert.\n"
"\n"
"Please load at least one supported video file to continue."
msgstr ""
"Il semble que vous n'avez chargé aucun fichier à convertir.\n"
"\n"
"Veuillez charger au moins un fichier vidéo pris en charge pour continuer."

#: davinci_helper/functions/gui/converter_dialog_gui.py:115
msgid "Select a valid file and output folder"
msgstr "Sélectionnez un fichier valide et un dossier de sortie"

#: davinci_helper/functions/gui/converter_dialog_gui.py:118
msgid ""
"It seems like you didn't load any file to convert\n"
"and you didn't choose any output folder.\n"
"\n"
"Please load at least one supported video file\n"
"and select a valid output folder to continue."
msgstr ""
"Il semble que vous n'avez chargé aucun fichier à convertir\n"
"et vous n'avez choisi aucun dossier de sortie.\n"
"\n"
"Veuillez charger au moins un fichier vidéo pris en charge\n"
"et sélectionner un dossier de sortie valide pour continuer."

#: davinci_helper/functions/gui/converter_dialog_gui.py:128
msgid "Select a valid output folder"
msgstr "Sélectionnez un dossier de sortie valide"

#: davinci_helper/functions/gui/converter_dialog_gui.py:131
msgid ""
"It seems like you didn't load any output folder.\n"
"\n"
"Please select a valid output folder to continue."
msgstr ""
"Il semble que vous n'avez sélectionné aucun dossier de sortie.\n"
"\n"
"Veuillez sélectionner un dossier de sortie valide pour continuer."

#: davinci_helper/functions/gui/converter_dialog_gui.py:141
msgid "Unsupported files found"
msgstr "Fichiers non pris en charge détectés"

#: davinci_helper/functions/gui/converter_dialog_gui.py:144
msgid ""
"Some files can't be converted because they are unsupported.\n"
"If you decide to continue, the following file will not be converted :\n"
msgstr ""
"Certains fichiers ne peuvent pas être convertis car ils ne sont pas pris en charge.\n"
"Si vous décidez de continuer, les fichiers suivants ne seront pas convertis :\n"

#. SETTING BUTTON TEXT LABEL
#: davinci_helper/functions/gui/converter_dialog_gui.py:159
#: data/ui/file_size_warning_dialog.ui:254
msgid "Continue"
msgstr "Continuer"

#: davinci_helper/functions/gui/converter_dialog_gui.py:172
msgid "All the files have been converted"
msgstr "Tous les fichiers ont été convertis"

#: davinci_helper/functions/gui/converter_dialog_gui.py:175
msgid ""
"All your files have been correctly converted\n"
"and placed inside your designed folder."
msgstr ""
"Tous vos fichiers ont été correctement convertis\n"
"et placés dans le dossier que vous avez choisi."

#: davinci_helper/functions/gui/converter_dialog_gui.py:185
msgid "Are you sure you want to exit ?"
msgstr "Êtes-vous sûr de vouloir quitter ?"

#: davinci_helper/functions/gui/converter_dialog_gui.py:188
msgid ""
"The video conversion is still going on,\n"
"if you exit this app the process will be interupted and\n"
"you will get only the files converted\n"
"before the app closure."
msgstr ""
"La conversion vidéo est toujours en cours,\n"
"si vous quittez cette application, le processus sera interrompu et\n"
"vous n'obtiendrez que les fichiers convertis\n"
"avant la fermeture de l'application."

#: davinci_helper/functions/gui/converter_dialog_gui.py:191
msgid "Continue conversion"
msgstr "Continuer la conversion"

#: davinci_helper/functions/gui/converter_dialog_gui.py:197
msgid "Exit app"
msgstr "Quitter l'application"

#: davinci_helper/functions/gui/file_error_dialog_gui.py:95
msgid "Select a valid file !"
msgstr "Sélectionnez un fichier valide !"

#: davinci_helper/functions/gui/file_error_dialog_gui.py:101
msgid ""
"It seems like you didn't load any file.\n"
"Please load a valid DaVinci Resolve installer file to continue."
msgstr ""
"Il semble que vous n'avez chargé aucun fichier.\n"
"Veuillez charger un fichier d'installation DaVinci Resolve valide pour continuer."

#: davinci_helper/functions/gui/file_error_dialog_gui.py:106
msgid ""
"It seems like you tried to load an usupported file.\n"
"Please load a valid DaVinci Resolve installer file to continue.\n"
"If you have renamed it, remember that the file name must\n"
"contain the words 'DaVinci', 'Resolve', 'Linux' inside of it\n"
"and it must to have the '.zip' or `.run` extension."
msgstr ""
"Il semble que vous avez essayé de charger un fichier non pris en charge.\n"
"Veuillez charger un fichier d'installation DaVinci Resolve valide pour continuer.\n"
"Si vous l'avez renommé, n'oubliez pas que le nom du fichier doit\n"
"contenir les mots 'DaVinci', 'Resolve', 'Linux'\n"
"et doit avoir l'extension '.zip' ou '.run'."

#: davinci_helper/functions/gui/file_size_warning_dialog_gui.py:109
msgid "This will need a lot of space !"
msgstr "Cela nécessitera beaucoup d'espace !"

#: davinci_helper/functions/gui/file_size_warning_dialog_gui.py:112
msgid ""
"The conversion of the files using the DNxHD/HR encoder will make new files "
"fully compatible with DaVinci Resolve Free.\n"
"\n"
"The use of these uncompressed sources will make your editing experience "
"faster, but it will take a lot of disk space.\n"
msgstr ""
"La conversion des fichiers avec l'encodeur DNxHD/HR créera de nouveaux fichiers "
"entièrement compatibles avec DaVinci Resolve Free.\n"
"\n"
"L'utilisation de ces sources non compressées rendra votre expérience de montage "
"plus rapide, mais cela prendra beaucoup d'espace disque.\n"

#: davinci_helper/functions/gui/file_size_warning_dialog_gui.py:115
#, python-brace-format
msgid ""
"The estimated disk space needed to convert the files is :\n"
"{space_placeholder}GB\n"
msgstr ""
"L'espace disque estimé nécessaire pour convertir les fichiers est :\n"
"{space_placeholder} Go\n"

#: davinci_helper/functions/gui/file_size_warning_dialog_gui.py:118
msgid ""
"If you want to use less disk space please consider using\n"
"lower video and audio settings."
msgstr ""
"Si vous souhaitez utiliser moins d'espace disque, veuillez envisager d'utiliser\n"
"des paramètres vidéo et audio plus bas."

#: davinci_helper/functions/gui/function_1_gui.py:152
msgid ""
"Check and install\n"
"missing dependencies"
msgstr ""
"Vérifier et installer\n"
"les dépendances manquantes"

#: davinci_helper/functions/gui/function_1_gui.py:155
msgid ""
"This part of the software will install all the dependencies necessary to "
"correctly launch the installation and the execution of DaVinci Resolve. The "
"script will detect your Fedora version and the libraries installed, after "
"that it will install only the packages needed. This script does not collect "
"or diffuse any information about you or your system. The internet connection "
"is required only if there are any missing libraries to install."
msgstr ""
"Cette partie du logiciel installera toutes les dépendances nécessaires pour "
"lancer correctement l'installation et l'exécution de DaVinci Resolve. Le "
"script détectera votre version de Fedora et les bibliothèques installées, puis "
"il n'installera que les paquets nécessaires. Ce script ne collecte ni ne diffuse "
"aucune information vous concernant ou concernant votre système. La connexion Internet "
"n'est requise que s'il y a des bibliothèques manquantes à installer."

