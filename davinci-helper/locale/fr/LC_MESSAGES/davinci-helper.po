#: davinci_helper/functions/gui/function_1_gui.py:406
msgid "The dependencies have been correctly installed"
msgstr "Les dépendances ont été correctement installées"

#: davinci_helper/functions/gui/function_1_gui.py:409
msgid ""
"All the dependencies have been correctly installed inside the system.\n"
"Now you can correctly start the DaVinci Resolve installer."
msgstr ""
"Toutes les dépendances ont été correctement installées dans le système.\n"
"Vous pouvez maintenant lancer correctement l'installateur de DaVinci Resolve."

#: davinci_helper/functions/gui/function_1_gui.py:426
msgid "There was an error installing the dependencies"
msgstr "Une erreur s'est produite lors de l'installation des dépendances"

#: davinci_helper/functions/gui/function_1_gui.py:434
msgid ""
"There was an error getting what version of Fedora you are using.\n"
"Please check the logs to have more details."
msgstr ""
"Une erreur s'est produite lors de la détection de votre version de Fedora.\n"
"Veuillez consulter les journaux pour plus de détails."

#: davinci_helper/functions/gui/function_1_gui.py:442
msgid ""
"There was an error getting the list of the installed libraries on your "
"system.\n"
"Please check the logs to have more details."
msgstr ""
"Une erreur s'est produite lors de la récupération de la liste des bibliothèques "
"installées sur votre système.\n"
"Veuillez consulter les journaux pour plus de détails."

#: davinci_helper/functions/gui/function_1_gui.py:450
msgid ""
"There was an error during the installation of the missing libraries.\n"
"Please check the logs to have more details."
msgstr ""
"Une erreur s'est produite lors de l'installation des bibliothèques manquantes.\n"
"Veuillez consulter les journaux pour plus de détails."

#: davinci_helper/functions/gui/function_1_gui.py:458
